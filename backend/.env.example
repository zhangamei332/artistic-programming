# 环境变量
PORT=3001

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# aiyiwei API (OpenAI compatible, GPT-5.5)
AIYIWEI_API_KEY=your_aiyiwei_api_key_here
AIYIWEI_BASE_URL=https://aiyiwei.vip/v1

# shiyunapi API (OpenAI compatible, Gemini-3.5)
SHIYUNAPI_API_KEY=your_shiyunapi_api_key_here
SHIYUNAPI_BASE_URL=https://shiyunapi.com/v1

# Mimo API (OpenAI compatible, mimo-v2.5-pro)
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# Gemini API (Google SDK, fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API (fallback)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
