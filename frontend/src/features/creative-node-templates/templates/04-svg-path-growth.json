{
  "id": "svg-path-growth",
  "version": "1.1.0",
  "name": "SVG路径生长",
  "nameEN": "SVG Path Growth",
  "category": "svg",
  "description": "解析SVG路径并按起点、中心、主干或分组顺序逐步生长。",
  "tags": [
    "SVG",
    "路径",
    "生长",
    "发光"
  ],
  "difficulty": "basic",
  "performance": "low",
  "graph": {
    "group": {
      "title": "SVG路径生长",
      "width": 1240,
      "height": 540,
      "collapsedByDefault": false,
      "layoutOnly": true,
      "renderFrame": false
    },
    "nodes": [
      {
        "id": "svg",
        "type": "source.svg",
        "label": "SVG输入",
        "position": {
          "x": 40,
          "y": 160
        },
        "params": {
          "fit": "contain"
        },
        "ui": {
          "width": 210,
          "collapsed": false
        }
      },
      {
        "id": "paths",
        "type": "analysis.svg-paths",
        "label": "路径解析",
        "position": {
          "x": 310,
          "y": 130
        },
        "params": {
          "sampleSpacing": 5,
          "sortMode": "length-desc"
        },
        "ui": {
          "width": 210,
          "collapsed": false
        }
      },
      {
        "id": "growth",
        "type": "modifier.path-growth",
        "label": "路径生长",
        "position": {
          "x": 610,
          "y": 120
        },
        "params": {
          "mode": "center-out",
          "speed": 0.18,
          "lineWidth": 1.5,
          "loop": true
        },
        "ui": {
          "width": 210,
          "collapsed": false
        }
      },
      {
        "id": "renderer",
        "type": "renderer.svg",
        "label": "SVG渲染",
        "position": {
          "x": 940,
          "y": 160
        },
        "params": {
          "width": 1920,
          "height": 1080,
          "strokeColor": "#ffd45e"
        },
        "ui": {
          "width": 210,
          "collapsed": false
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "svg",
        "sourcePort": "svg",
        "target": "paths",
        "targetPort": "svg",
        "label": "SVG → 路径",
        "mappings": [
          {
            "id": "m1",
            "mode": "direct",
            "input": "svg",
            "output": "svg",
            "label": "SVG → 路径解析",
            "curve": "linear",
            "clamp": false,
            "smoothing": {
              "type": "none",
              "amount": 0
            }
          }
        ]
      },
      {
        "id": "e2",
        "source": "paths",
        "sourcePort": "paths",
        "target": "growth",
        "targetPort": "paths",
        "label": "路径 → 生长",
        "mappings": [
          {
            "id": "m2",
            "mode": "direct",
            "input": "paths",
            "output": "paths",
            "label": "路径 → 生长输入",
            "curve": "linear",
            "clamp": false,
            "smoothing": {
              "type": "none",
              "amount": 0
            }
          }
        ]
      },
      {
        "id": "e3",
        "source": "growth",
        "sourcePort": "paths",
        "target": "renderer",
        "targetPort": "paths",
        "label": "生长路径 → 输出",
        "mappings": [
          {
            "id": "m3",
            "mode": "direct",
            "input": "paths",
            "output": "paths",
            "label": "显示路径 → SVG渲染",
            "curve": "linear",
            "clamp": false,
            "smoothing": {
              "type": "none",
              "amount": 0
            }
          }
        ]
      }
    ]
  },
  "insertion": {
    "surface": "host-node-canvas",
    "renderGroupFrame": false,
    "useHostNodeComponents": true,
    "useHostEdgeComponent": true,
    "useHostInspector": true,
    "reuseExistingSystemNodes": true,
    "insertAsSingleUndoTransaction": true
  }
}
